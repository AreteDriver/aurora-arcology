# Aurora — local SQLite store. Curator regenerates from data/seeds/*.json.
# Vercel build also regenerates via `pnpm vercel:build` so the deployed
# read-only DB is always in sync with seeds at build time.
data/aurora.db
data/aurora.db-journal
data/aurora.db-shm
data/aurora.db-wal

# Aurora — local raw source material under L3 user-paste licensing.
# Transcripts, captions, and downloaded creator content stay out of git.
# Only curator-authored seed JSON (data/seeds/*.json) is tracked.
data/raw/
*.vtt
*.srt
.vercel

# Aurora — generated DB blob for Vercel function packaging.
# Refreshed by `pnpm embed:db` from data/aurora.db; ships only inside the
# Vercel build artifact, never tracked.
src/lib/db-blob.ts
data/syntheses/_input/
