{
  "name": "aurora-arcology",
  "version": "0.1.0",
  "private": false,
  "description": "Aurora — investigation-board framework for narrative universes. First instance: EVE Online lore.",
  "license": "MIT",
  "scripts": {
    "postinstall": "node scripts/ensure-db-blob.mjs",
    "db:blob:ensure": "node scripts/ensure-db-blob.mjs",
    "dev": "pnpm db:blob:ensure && next dev",
    "build": "pnpm db:blob:ensure && next build",
    "start": "pnpm db:blob:ensure && next start",
    "lint": "pnpm db:blob:ensure && eslint .",
    "smoke:routes": "bash scripts/smoke-routes.sh",
    "typecheck": "pnpm db:blob:ensure && tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx scripts/migrate.ts",
    "db:seed": "tsx scripts/seed.ts",
    "db:clean": "rm -f data/aurora.db data/aurora.db-journal data/aurora.db-wal data/aurora.db-shm",
    "db:reset": "pnpm db:clean && pnpm db:migrate && pnpm news:load && pnpm chronicle:load && pnpm ash:load && pnpm db:seed",
    "ash:load": "tsx scripts/seed.ts data/seeds/ash_timeline.json",
    "news:scrape": "tsx scripts/scrape-news.ts",
    "news:scrape:full": "tsx scripts/scrape-news.ts --full",
    "news:load": "tsx scripts/seed.ts data/seeds/news_archive.json",
    "chronicle:scrape": "tsx scripts/scrape-chronicles.ts",
    "chronicle:scrape:full": "tsx scripts/scrape-chronicles.ts --full",
    "chronicle:load": "tsx scripts/seed.ts data/seeds/chronicle_archive.json",
    "resolver:audit": "tsx scripts/resolve.ts",
    "ner:extract": "tsx scripts/ner-extract.ts",
    "admin": "tsx scripts/admin.ts",
    "embed:db": "tsx scripts/embed-db.ts",
    "manifest:build": "tsx scripts/build-manifest.ts",
    "synthesize:polish": "tsx scripts/synthesize-polish.ts",
    "synthesize:dump": "tsx scripts/dump-lens-md.ts",
    "synthesize:dedupe": "tsx scripts/synthesize-dedupe.ts",
    "market:load": "tsx scripts/load-market-data.ts",
    "vercel:build": "pnpm db:reset && pnpm ner:extract && pnpm manifest:build && next build"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.95.0",
    "better-sqlite3": "^11.5.0",
    "d3": "^7.9.0",
    "drizzle-orm": "^0.36.0",
    "fastest-levenshtein": "^1.0.16",
    "graphology": "^0.26.0",
    "graphology-components": "^1.5.4",
    "graphology-metrics": "^2.4.0",
    "graphology-types": "^0.24.8",
    "next": "^15.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/d3": "^7.4.3",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.20",
    "drizzle-kit": "^0.28.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "^15.0.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  },
  "packageManager": "pnpm@9.12.0"
}
